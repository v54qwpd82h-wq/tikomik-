const mouthFrames=[true,false,true,false,true];

let idx=0;

const fr=()=>{
 if(!isSpeaking){
   fullRedrawWithStrokes(false,false);
   return;
 }

 idx=(idx+1)%mouthFrames.length;

 fullRedrawWithStrokes(
   c1 ? mouthFrames[idx] : false,
   c2 ? mouthFrames[idx] : false
 );

 mouthAnimFrame=setTimeout(fr,90);
}